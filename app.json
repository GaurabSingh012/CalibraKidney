{
  "expo": {
    "name": "CalibraKidney",
    "slug": "calibrakidney-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.gaurab.calibrakidney",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-asset",
      [
        "react-native-vision-camera",
        {
          "enableFrameProcessors": true,
          "cameraPermissionText": "CalibraKidney needs access to your camera to scan test strips."
        }
      ],
      "react-native-fast-tflite",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "usesCleartextTraffic": true,
            "newArchEnabled": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "50061a2b-c46a-4efd-a7e2-bb40cca25c74"
      }
    },
    "owner": "rabgaukus"
  }
}
